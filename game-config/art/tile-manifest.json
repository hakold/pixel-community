{
  "version": "1.0",
  "description": "Tile type → visual config. Sprite takes priority; procedural is the fallback.",
  "tiles": {
    "grass": {
      "layer": "ground",
      "anchor": { "x": 0.5, "y": 0.5 },
      "sprite": "/assets/sprites/tiles/grass_iso_01.png",
      "spriteScale": 3,
      "render": {
        "mode": "diamond",
        "colors": {
          "fill": "#88c05d",
          "stroke": "rgba(53, 85, 33, 0.2)",
          "highlight": "rgba(255,255,255,0.03)"
        }
      }
    },
    "ground": {
      "layer": "ground",
      "anchor": { "x": 0.5, "y": 0.5 },
      "sprite": "/assets/sprites/tiles/interior_floor_beige_01.png",
      "spriteScale": 3,
      "render": {
        "mode": "diamond",
        "colors": {
          "fill": "#f2e5cc",
          "stroke": "rgba(124, 96, 69, 0.18)"
        }
      }
    },
    "wall": {
      "layer": "raised",
      "anchor": { "x": 0.5, "y": 1.0 },
      "sprite": "/assets/sprites/buildings/interior_wall_white_01.png",
      "spriteScale": 3,
      "render": {
        "mode": "block",
        "colors": {
          "top": "#d7dbe1",
          "left": "#aeb5bf",
          "right": "#9199a5"
        }
      }
    }
  }
}
