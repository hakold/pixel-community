# 前端开发服务器监听地址
# 需要局域网测试时改成 0.0.0.0；默认是 localhost
VITE_DEV_HOST=localhost

# 后端服务地址
# 开发时可指向本地后端，部署时改为实际地址（如 https://your-server.com）
VITE_SERVER_URL=http://localhost:3000

# 开发代理目标
# 这里只填写前端代理真正转发到的后端地址，不要写 0.0.0.0
VITE_API_PROXY_TARGET=http://127.0.0.1:3000

# 开发环境下 WebSocket 直连后端时使用的端口
VITE_SERVER_PORT=3000
