{
  "name": "pixel-community-client",
  "version": "1.0.0",
  "description": "《像素社区》游戏客户端",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite --host=0.0.0.0",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://0.0.0.0:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "preview": "vite preview"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "pinia": "^2.2.2",
    "vue": "^3.5.4",
    "vue-router": "^4.4.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.3",
    "concurrently": "^9.0.1",
    "electron": "^32.1.0",
    "electron-builder": "^25.0.5",
    "vite": "^5.4.3",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "com.pixelcommunity.app",
    "productName": "像素社区",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
